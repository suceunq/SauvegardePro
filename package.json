    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
